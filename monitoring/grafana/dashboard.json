{
  "uid": "mediassist-monitoring",
  "title": "MediAssist AI — Monitoring",
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Accuracy du modèle ML",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "mediassist_model_accuracy", "legendFormat": "Accuracy" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.70 },
              { "color": "green", "value": 0.80 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Consultations totales",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "mediassist_consultations_total", "legendFormat": "Consultations" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 3,
      "title": "Messages chatbot totaux",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "mediassist_chat_messages_total", "legendFormat": "Messages" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "id": 4,
      "title": "Taux d'erreurs HTTP (%)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "rate(mediassist_http_requests_total{status_code=~\"5..\"}[5m]) / rate(mediassist_http_requests_total[5m]) * 100", "legendFormat": "Erreurs %" }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Prédictions par orientation",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 4, "w": 8, "h": 8 },
      "targets": [
        { "expr": "mediassist_predictions_total{orientation=\"urgences\"}", "legendFormat": "Urgences" },
        { "expr": "mediassist_predictions_total{orientation=\"medecin\"}", "legendFormat": "Médecin" },
        { "expr": "mediassist_predictions_total{orientation=\"surveillance\"}", "legendFormat": "Surveillance" }
      ]
    },
    {
      "id": 6,
      "title": "Distribution scores de gravité",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 4, "w": 16, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(mediassist_severity_score_bucket[5m]))", "legendFormat": "Médiane (P50)" },
        { "expr": "histogram_quantile(0.90, rate(mediassist_severity_score_bucket[5m]))", "legendFormat": "P90" },
        { "expr": "histogram_quantile(0.95, rate(mediassist_severity_score_bucket[5m]))", "legendFormat": "P95" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "max": 100 } }
    },
    {
      "id": 7,
      "title": "Requêtes API / minute",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(mediassist_http_requests_total{status_code=~\"2..\"}[1m]) * 60", "legendFormat": "2xx Succès" },
        { "expr": "rate(mediassist_http_requests_total{status_code=~\"4..\"}[1m]) * 60", "legendFormat": "4xx Client" },
        { "expr": "rate(mediassist_http_requests_total{status_code=~\"5..\"}[1m]) * 60", "legendFormat": "5xx Erreur" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Latence API (secondes)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rate(mediassist_http_request_duration_seconds_sum[5m]) / rate(mediassist_http_request_duration_seconds_count[5m])", "legendFormat": "Latence moyenne" },
        { "expr": "histogram_quantile(0.95, rate(mediassist_http_request_duration_seconds_bucket[5m]))", "legendFormat": "P95" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 9,
      "title": "Latence par endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "targets": [
        { "expr": "rate(mediassist_http_request_duration_seconds_sum{endpoint=\"/analysis/analyze\"}[5m]) / rate(mediassist_http_request_duration_seconds_count{endpoint=\"/analysis/analyze\"}[5m])", "legendFormat": "/analysis/analyze" },
        { "expr": "rate(mediassist_http_request_duration_seconds_sum{endpoint=\"/chat/message\"}[5m]) / rate(mediassist_http_request_duration_seconds_count{endpoint=\"/chat/message\"}[5m])", "legendFormat": "/chat/message" },
        { "expr": "rate(mediassist_http_request_duration_seconds_sum{endpoint=\"/auth/login\"}[5m]) / rate(mediassist_http_request_duration_seconds_count{endpoint=\"/auth/login\"}[5m])", "legendFormat": "/auth/login" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}