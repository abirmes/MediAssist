{
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Prédictions (Orientation)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(predictions_total) or vector(0)", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "mappings": [] }
      }
    },
    {
      "title": "Messages Chat",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "expr": "chat_messages_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "title": "Consultations Générées",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "expr": "consultations_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "title": "Gravité Moyenne (Score)",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "severity_score_sum / severity_score_count", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 40 },
              { "color": "red", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "title": "Utilisation RAM (Mo)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [{ "expr": "process_resident_memory_bytes / 1024 / 1024", "refId": "A" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 }, "unit": "decbytes" } }
    },
    {
      "title": "Charge CPU (Sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [{ "expr": "rate(process_cpu_seconds_total[1m])", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" } }
    },
    {
      "title": "Garbage Collection (Objets collectés)",
      "type": "barchart",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 14 },
      "targets": [{ "expr": "python_gc_objects_collected_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    },
    {
      "title": "Fichiers Ouverts (FDS)",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 14 },
      "targets": [{ "expr": "process_open_fds", "refId": "A" }],
      "fieldConfig": { "defaults": { "min": 0, "max": 100 } }
    },
    {
      "title": "Uptime Système",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 14 },
      "targets": [{ "expr": "time() - process_start_time_seconds", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mediassist", "python", "mlops"],
  "time": { "from": "now-30m", "to": "now" },
  "title": "MediAssist - Full Monitoring",
  "uid": "mediassist_full_001"
}